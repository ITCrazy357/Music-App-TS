mixin search(keyword)
    form(id="form-search")
        .search-form(style="max-width: 450px; margin-left: auto;")
            input(
                type="text"
                placeholder="Nhập từ khóa..."
                name="keyword"
                value=keyword
            )
            button(
                class="btn-search"
                type="submit"
            )
                i.fa-solid.fa-magnifying-glass
