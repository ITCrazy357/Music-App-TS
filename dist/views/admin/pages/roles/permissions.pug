extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
    .container-fluid.px-4.px-lg-5.my-3

        .row
            .col-12
                +box-head(pageTitle)

        if roles && roles.length > 0
            div(data-records=roles)
            .card.custom-list-card.mb-3
                .card-header
                    | Ma trận phân quyền
                .card-body
                    .custom-actions.mb-3
                        button(
                            type="button"
                            class="btn btn-warning"
                            button-submit-permissions
                        )
                            i.fa-solid.fa-floppy-disk.mr-1
                            | Cập nhật phân quyền

                    .table-responsive
                        table.table.custom-table.table-hover.table-permissions(table-permissions)
                            thead
                                tr
                                    th Tính năng
                                    each item in roles
                                        th.text-center #{item.title}
                            tbody
                                tr.d-none(data-name="id")
                                    td
                                    each item in roles
                                        td.text-center
                                            input(type="text" value=item.id)
                                //- Topics
                                tr
                                    td(colspan=roles.length + 1)
                                        b Quản lý chủ đề
                                tr(data-name="topics_view")
                                    td Xem
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="topics_create")
                                    td Thêm mới
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="topics_edit")
                                    td Chỉnh sửa
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="topics_delete")
                                    td Xóa
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")

                                //- Songs
                                tr
                                    td(colspan=roles.length + 1)
                                        b Quản lý bài hát
                                tr(data-name="songs_view")
                                    td Xem
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="songs_create")
                                    td Thêm mới
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="songs_edit")
                                    td Chỉnh sửa
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="songs_delete")
                                    td Xóa
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                            
                                //- Singers
                                tr
                                    td(colspan=roles.length + 1)
                                        b Quản lý ca sĩ
                                tr(data-name="singers_view")
                                    td Xem
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="singers_create")
                                    td Thêm mới
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="singers_edit")
                                    td Chỉnh sửa
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="singers_delete")
                                    td Xóa
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                            
                                //- Users
                                tr
                                    td(colspan=roles.length + 1)
                                        b Quản lý tài khoản
                                tr(data-name="users_view")
                                    td Xem
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="users_create")
                                    td Thêm mới
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="users_edit")
                                    td Chỉnh sửa
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="users_delete")
                                    td Xóa
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                            
                                //- Roles
                                tr
                                    td(colspan=roles.length + 1)
                                        b Quản lý nhóm quyền
                                tr(data-name="roles_view")
                                    td Xem
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="roles_create")
                                    td Thêm mới
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="roles_edit")
                                    td Chỉnh sửa
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="roles_delete")
                                    td Xóa
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")
                                tr(data-name="roles_permissions")
                                    td Phân quyền
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")

                                //- Ads
                                tr(data-name="ads_view")
                                    td Xem quảng cáo
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")

                                tr(data-name="ads_create")
                                    td Tạo quảng cáo
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")

                                tr(data-name="ads_edit")
                                    td Chỉnh sửa quảng cáo
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")

                                tr(data-name="ads_delete")
                                    td Xóa quảng cáo
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")

                                tr(data-name="ads_statistics")
                                    td Thống kê quảng cáo
                                    each item in roles
                                        td.text-center
                                            input(type="checkbox")


            form(
                id="form-change-permissions"
                method="POST"
                action=`/${prefixAdmin}/roles/permissions?_method=PATCH`
                class="d-none"
            )
                div.form-group
                    input(
                        type="text"
                        class="form-control"
                        name="permissions"
                    )

        else
            div.alert.alert-secondary Không có nhóm quyền nào.
