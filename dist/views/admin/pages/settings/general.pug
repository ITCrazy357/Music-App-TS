extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container-fluid.px-4.px-lg-5.my-3
    .row
      .col-12
        +box-head(pageTitle)
    
    .card.mb-3.admin-form-card
      .card-header Cài đặt chung
      .card-body
        form.admin-form(
          action=`/${prefixAdmin}/settings/general?_method=PATCH`
          method="POST"
          enctype="multipart/form-data"
        )
          .row
            .col-md-6
              .form-group
                label(for="websiteName") Tên thương hiệu
                input(
                  type="text"
                  class="form-control"
                  id="websiteName"
                  name="websiteName"
                  value=(settingGeneral ? settingGeneral.websiteName : "")
                  required
                )
            
            .col-md-6
              .form-group
                label(for="shortDescription") Mô tả ngắn
                input(
                  type="text"
                  class="form-control"
                  id="shortDescription"
                  name="shortDescription"
                  value=(settingGeneral ? settingGeneral.shortDescription : "")
                )
                
            .col-md-6
              .form-group
                label(for="logo") Logo Website
                input.form-control-file.upload-image-input(
                  type="file"
                  id="logo"
                  name="logo"
                  accept="image/*"
                )
                img.admin-preview-image.upload-image-preview(
                  src=(settingGeneral && settingGeneral.logo ? settingGeneral.logo : "")
                  alt="Logo"
                  style=`display: ${(settingGeneral && settingGeneral.logo) ? 'block' : 'none'}; max-width: 150px; margin-top: 10px; border-radius: 8px;`
                )

            .col-md-6
              .form-group
                label(for="favicon") Favicon
                input.form-control-file.upload-image-input(
                  type="file"
                  id="favicon"
                  name="favicon"
                  accept="image/*"
                )
                img.admin-preview-image.upload-image-preview(
                  src=(settingGeneral && settingGeneral.favicon ? settingGeneral.favicon : "")
                  alt="Favicon"
                  style=`display: ${(settingGeneral && settingGeneral.favicon) ? 'block' : 'none'}; max-width: 50px; margin-top: 10px; border-radius: 8px;`
                )

          .row.mt-3
            .col-md-4
              .form-group
                label(for="phone") Số điện thoại
                input(
                  type="text"
                  class="form-control"
                  id="phone"
                  name="phone"
                  value=(settingGeneral ? settingGeneral.phone : "")
                )
            
            .col-md-4
              .form-group
                label(for="email") Email
                input(
                  type="email"
                  class="form-control"
                  id="email"
                  name="email"
                  value=(settingGeneral ? settingGeneral.email : "")
                )
            
            .col-md-4
              .form-group
                label(for="address") Địa chỉ
                input(
                  type="text"
                  class="form-control"
                  id="address"
                  name="address"
                  value=(settingGeneral ? settingGeneral.address : "")
                )
          
          .row.mt-3
            .col-md-6
              .form-group
                label(for="copyright") Copyright Footer
                input(
                  type="text"
                  class="form-control"
                  id="copyright"
                  name="copyright"
                  value=(settingGeneral ? settingGeneral.copyright : "")
                )

            .col-md-6
              .form-group
                label(for="facebook") Link Facebook
                input(
                  type="text"
                  class="form-control"
                  id="facebook"
                  name="facebook"
                  value=(settingGeneral ? settingGeneral.facebook : "")
                )
            
            .col-md-4
              .form-group
                label(for="youtube") Link YouTube
                input(
                  type="text"
                  class="form-control"
                  id="youtube"
                  name="youtube"
                  value=(settingGeneral ? settingGeneral.youtube : "")
                )
                
            .col-md-4
              .form-group
                label(for="tiktok") Link TikTok
                input(
                  type="text"
                  class="form-control"
                  id="tiktok"
                  name="tiktok"
                  value=(settingGeneral ? settingGeneral.tiktok : "")
                )
                
            .col-md-4
              .form-group
                label(for="instagram") Link Instagram
                input(
                  type="text"
                  class="form-control"
                  id="instagram"
                  name="instagram"
                  value=(settingGeneral ? settingGeneral.instagram : "")
                )

          .form-group.mt-4
            button(type="submit" class="btn btn-primary")
              i.fa-solid.fa-save.mr-1
              | Lưu thay đổi
