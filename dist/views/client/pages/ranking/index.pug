extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
    style.
        .ranking-item {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 15px;
        }
        .ranking-number {
            font-size: 2rem;
            font-weight: bold;
            width: 60px;
            text-align: center;
            color: var(--color-primary);
        }
        .ranking-image {
            width: 80px;
            height: 80px;
            border-radius: 8px;
            overflow: hidden;
            margin-right: 20px;
            flex-shrink: 0;
        }
        .ranking-info {
            flex: 1;
            min-width: 0;
            padding-right: 10px;
        }
        .ranking-title {
            margin: 0 0 5px 0;
            font-size: 1.2rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .ranking-stats {
            text-align: right;
            color: #aaa;
            flex-shrink: 0;
        }
        @media (max-width: 576px) {
            .ranking-item {
                flex-wrap: wrap;
                position: relative;
            }
            .ranking-number {
                width: 40px;
                font-size: 1.5rem;
            }
            .ranking-image {
                width: 60px;
                height: 60px;
                margin-right: 15px;
            }
            .ranking-stats {
                width: 100%;
                text-align: left;
                margin-top: 10px;
                padding-left: 55px;
                display: flex;
                align-items: center;
                gap: 5px;
            }
        }

    .container.my-3
        .row 
            .col-12 
                +box-head(pageTitle)

        .row
            .col-12
                .ranking-list
                    each song, index in rankingSongs
                        - var rankClass = index === 0 ? "rank-1" : index === 1 ? "rank-2" : index === 2 ? "rank-3" : "rank-other";
                        - var rankIcon = index === 0 ? "🥇" : index === 1 ? "🥈" : index === 2 ? "🥉" : `#${index + 1}`;
                        
                        .ranking-item(class=rankClass)
                            .ranking-number #{rankIcon}
                            
                            .ranking-image
                                a(href=`/songs/detail/${song.slug}`)
                                    img(src=song.avatar alt=song.title style="width: 100%; height: 100%; object-fit: cover;")
                            
                            .ranking-info
                                h3.ranking-title
                                    a(href=`/songs/detail/${song.slug}` style="color: white; text-decoration: none;") #{song.title}
                                p.ranking-singer(style="margin: 0; color: #aaa; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;")
                                    i(class="fa-solid fa-microphone-lines")
                                    |  #{song.singerInfo ? song.singerInfo.fullName : 'Chưa rõ'}
                            
                            .ranking-stats
                                div(style="font-size: 1.1rem; font-weight: bold; color: var(--color-primary);") #{song.listen} 
                                div(style="font-size: 0.8rem;") lượt nghe
