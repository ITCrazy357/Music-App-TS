extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
    .container.my-3
        .row.mb-5
            .col-12
                .singer-detail-card(style="background: rgba(255, 255, 255, 0.05); border-radius: 15px; padding: 30px; display: flex; align-items: center; gap: 30px; flex-wrap: wrap;")
                    .singer-avatar(style="width: 200px; height: 200px; border-radius: 50%; overflow: hidden; border: 4px solid var(--color-primary); flex-shrink: 0;")
                        img(src=singer.avatar alt=singer.fullName style="width: 100%; height: 100%; object-fit: cover;")
                    .singer-info(style="flex: 1; min-width: 300px;")
                        h1.singer-name(style="font-size: 2.5rem; font-weight: 700; margin-bottom: 15px;") #{singer.fullName}
                        .singer-stats(style="display: flex; gap: 20px; margin-bottom: 20px;")
                            .stat-item(style="text-align: center; background: rgba(0,0,0,0.3); padding: 10px 20px; border-radius: 10px;")
                                .stat-value(style="font-size: 1.5rem; font-weight: bold; color: var(--color-primary);") #{singer.totalSongs}
                                .stat-label(style="font-size: 0.9rem; color: #aaa;") Bài hát
                        //- Nếu model có bio hoặc mô tả thì hiển thị ở đây
                        //- if singer.description
                        //-     .singer-bio !{singer.description}

        .row 
            .col-12 
                +box-head("Danh sách bài hát")

        .row
            if songs.length > 0
                each song in songs
                    .col-12.col-sm-6.col-md-4.col-lg-3.mb-3
                        div(class="song-item")
                            div(class="inner-image")
                                a(href=`/songs/detail/${song.slug}`)
                                    img(src=`${song.avatar}` alt=`${song.title}`) 

                            div(class="inner-content")
                                div(class="inner-title")
                                    a(href=`/songs/detail/${song.slug}`) #{song.title}

                                div(class="inner-singer")
                                    i(class="fa-solid fa-microphone-lines")
                                    |  #{singer.fullName}

                                div(class="inner-listen" style="color: #ffffff;")
                                    i(class="fa-solid fa-headphones" style="color: #ffffff;")
                                    |  #{song.listen || 0} lượt nghe
                                
                                div(class=`inner-like ${song.isLiked ? 'active' : ''}` button-like=song._id)
                                    i(class="fa-solid fa-thumbs-up")
                                    span  #{song.likes ? song.likes.length : 0} lượt thích
            else
                .col-12
                    p.text-center(style="color: #aaa;") Ca sĩ này chưa có bài hát nào.