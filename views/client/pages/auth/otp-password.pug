extends ../../layouts/default.auth.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)
    +alert-success(5000)

    .auth.auth-otp-password
        .auth-container
            .auth-wrapper.wrapper
                form.auth-form(
                    action="/auth/otp"
                    method="POST"
                )

                    //- Tiêu đề
                    .auth-header
                        +box-head(pageTitle)

                    //- Countdown
                    .auth-countdown
                        span#countdown-time 60

                    //- Email (hidden or read-only)
                    .auth-group.input-box
                        .auth-input-group.inner-email
                            input.auth-input(
                                type="email"
                                name="email"
                                value=email
                                readonly
                                required
                            )

                            i.bx.bx-envelope.auth-icon

                    //- OTP
                    .auth-group.input-box
                        .auth-input-group.inner-otp
                            input.auth-input(
                                type="text"
                                name="otp"
                                placeholder="Nhập mã OTP"
                                maxlength="6"
                                required
                            )

                            i.bx.bx-key.auth-icon

                    //- Resend link
                    .auth-resend
                        a.auth-resend-link(
                            href="/auth/forgot-password?email=" + email
                            id="resend-link"
                        ) Gửi lại mã OTP

                    //- Button verify
                    .auth-action
                        button.auth-button.btn(
                            type="submit"
                        ) Xác thực

                    //- Back to login link
                    .auth-footer.register-link
                        p.auth-text
                            | Nhớ mật khẩu?

                            a.auth-register-link(
                                href="/auth/login"
                            )  Đăng nhập

    script.
        // Countdown timer
        var timeLeft = 60;
        var countdownElement = document.getElementById('countdown-time');
        var resendLink = document.getElementById('resend-link');

        var timer = setInterval(function() {
            timeLeft--;
            countdownElement.textContent = timeLeft;

            if (timeLeft <= 0) {
                clearInterval(timer);
                countdownElement.textContent = "Hết hạn";
                resendLink.style.pointerEvents = 'auto';
                resendLink.style.opacity = '1';
            }
        }, 1000);

        // Disable resend link initially
        if (resendLink) {
            resendLink.style.pointerEvents = 'none';
            resendLink.style.opacity = '0.5';
        }