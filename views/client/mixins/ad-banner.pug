mixin ad-banner(adsList)
  if adsList && adsList.length > 0
    style.
      .ads-swiper-container {
        width: 100%;
        margin-bottom: 1.5rem;
        border-radius: 8px;
        overflow: hidden;
      }
      .ads-banner-inner {
        position: relative;
        text-align: center;
        border-radius: 8px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

    .swiper.ads-swiper-container
      .swiper-wrapper
        each ad in adsList
          .swiper-slide
            .ads-banner-inner.ad-banner-container(data-ad-id=ad._id)
              if ad.sponsorLevel
                span.badge.badge-warning.position-absolute(style="top: 10px; left: 10px; z-index: 10;") #{ad.sponsorLevel} Tài Trợ
              a(href=`/ads/click/${ad._id}` target="_blank" rel="noopener noreferrer" style="display: block; text-decoration: none; height: 100%;")
                if ad.image
                  img.img-fluid(src=ad.image alt=ad.title style="max-height: 250px; width: 100%; object-fit: cover; height: 100%;")
                else
                  .p-4.text-white
                    h5.mb-2(style="color: var(--primary-color, #18b283);") #{ad.title}
                    if ad.description
                      p.mb-0.text-muted !{ad.description}
