header.header.py-3
  .container-fluid.px-4.px-lg-5
    .row.align-items-center
      .col-lg-2.col-md-4.col-6
        .inner-logo
          a.d-flex.align-items-center.gap-2(href="/topics")
            img(
              src="/images/logo.png",
              alt="Music Streaming Logo",
              width="50"
            )

            span.logo-text Music Streaming

      .col-lg-6.d-none.d-lg-block
        nav.inner-menu
          ul.d-flex.align-items-center.justify-content-center.gap-4.mb-0
            li
              a(href="/topics") Trang chủ

            li
              a(href="/songs") Bài hát

            li
              a(href="/topics") Chủ đề

            li
              a(href="/singers") Ca sĩ

            li
              a(href="/favorite-songs") Bài hát yêu thích

            li
              a(href="/ranking") BXH

      .col-lg-4.col-md-8.col-6
        .header-actions.d-flex.align-items-center.justify-content-end.gap-3
          form.search-form.d-none.d-md-flex(action="/search", method="GET")
            input.form-control(
              type="text",
              name="keyword",
              placeholder="Tìm kiếm bài hát..."
            )

            button.btn.btn-primary(type="submit")
              i.fa-solid.fa-magnifying-glass

          if user
            a(href="/auth/info", class="inner-actions__item d-flex align-items-center gap-2", title="Thông tin cá nhân")
              i.fa-solid.fa-user
              span #{user.fullName}
    
            a(href="/auth/logout", class="inner-actions__item", title="Đăng xuất")
              i.fa-solid.fa-right-from-bracket
          else
            a(href="/auth/login", class="inner-actions__item", title="Đăng nhập")
              i.fa-solid.fa-user
            a(href="/auth/register", class="inner-actions__item", title="Đăng ký")
              i.fa-solid.fa-user-plus