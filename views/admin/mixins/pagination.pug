mixin pagination(pagination)
    if pagination.totalPage > 0
        nav
            ul(class="pagination")
                li(class=`page-item ${pagination.currentPage == 1 ? "disabled" : ""}`)
                    button(
                        class="page-link" 
                        button-pagination = 1
                    )
                        i.fa-solid.fa-angles-left
                li(class=`page-item ${pagination.currentPage == 1 ? "disabled" : ""}`)
                    button(
                        class="page-link" 
                        button-pagination = pagination.currentPage - 1
                    )
                        i.fa-solid.fa-angle-left
                
                - for(var i = 1; i<= pagination.totalPage; i++)
                    li(class=`page-item ${pagination.currentPage == i ? "active" : ""}`)
                        button(
                            class="page-link"
                            button-pagination = i
                        ) #{i}
                
                li(class=`page-item ${pagination.currentPage == pagination.totalPage ? "disabled" : ""}`)
                    button(
                        class="page-link"
                        button-pagination = pagination.currentPage + 1
                    )
                        i.fa-solid.fa-angle-right
                li(class=`page-item ${pagination.currentPage == pagination.totalPage ? "disabled" : ""}`)
                    button(
                        class="page-link" 
                        button-pagination = pagination.totalPage
                    )
                        i.fa-solid.fa-angles-right

