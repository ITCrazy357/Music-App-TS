extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
    .container-fluid.px-4.px-lg-5.my-3
        .row 
            .col-12 
                +box-head(pageTitle)

        .card.mb-3.song-list-card
            .card-header Danh sách bài hát
            .card-body
                .song-actions 
                    a(
                        href=`/${prefixAdmin}/songs/create`
                        class="btn btn-outline-success mr-2"
                    )
                        i.fa-solid.fa-plus.mr-1
                        | Thêm mới
                    a(
                        href=`/${prefixAdmin}/songs/trash`
                        class="btn btn-outline-danger"
                    )
                        i.fa-solid.fa-trash-can.mr-1
                        | Thùng rác

                if songs.length > 0
                    table.table.song-table(
                        class="table table-hover table-sm mt-3"
                        checkbox-multi
                    )
                        thead
                            tr
                                th STT
                                th Hình ảnh
                                th Tiêu đề
                                th Lượt nghe
                                th Trạng thái
                                th Hành động
                        tbody
                            each item, index in songs
                                tr 
                                    td #{index + 1}
                                    td
                                        img.song-avatar(
                                            src=item.avatar
                                            alt=item.title
                                            width="80px"
                                            height="auto"
                                            style="border-radius: 8px;"
                                        )
                                    td.song-title #{item.title}
                                    td.song-listen #{item.listen}
                                    td
                                        if (item.status === "active")
                                            a.song-status-active(
                                                href="javascript:;"
                                                class="badge badge-success"
                                                data-status="active"
                                                data-id=item.id
                                                button-change-status
                                            ) Hoạt động
                                        else
                                            a.song-status-inactive(
                                                href="javascript:;"
                                                class="badge badge-danger"
                                                data-status="inactive"
                                                data-id=item.id
                                                button-change-status
                                            ) Dừng hoạt động
                                    td
                                        .song-actions-group
                                            a(
                                                href=`/${prefixAdmin}/songs/detail/${item.id}`
                                                class="btn btn-secondary btn-sm mr-1"
                                            )
                                                i.fa-solid.fa-circle-info.mr-1
                                                | Chi tiết
                                            a(
                                                href=`/${prefixAdmin}/songs/edit/${item.id}`
                                                class="btn btn-warning btn-sm mr-1"
                                            )
                                                i.fa-solid.fa-pen-to-square.mr-1
                                                | Sửa
                                            button(
                                                class="btn btn-danger btn-sm"
                                                button-delete
                                                data-id=item.id
                                            )
                                                i.fa-solid.fa-trash.mr-1
                                                | Xóa

                else
                    div.alert.alert-secondary.song-empty.mt-3 Không có bài hát nào.

        form(
            action=""
            method="POST"
            id="form-change-status"
            data-path=`/${prefixAdmin}/songs/change-status`
        )

        form(
            action=""
            method="POST"
            id="form-delete-item"
            data-path=`/${prefixAdmin}/songs/delete`
        )