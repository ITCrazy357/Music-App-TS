extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
    .container-fluid.px-4.px-lg-5.my-3
        .row 
            .col-12 
                +box-head(pageTitle)

        .card.mb-3
            .card-header Danh sách bài hát
            .card-body
                .row 
                    .col-8 
                    .col-4.text-right 
                        a(
                            href=`/${prefixAdmin}/songs/create`
                            class="btn btn-outline-success"
                        ) + Thêm mới

                table(
                    class="table table-hover table-sm mt-3"
                    checkbox-multi
                )
                    thead
                        tr
                            th STT
                            th Hình ảnh
                            th Tiêu đề
                            th Lượt nghe
                            th Trạng thái
                            th Hành động
                    tbody
                        each item, index in songs
                            tr 
                                td #{index + 1}
                                td
                                    img(
                                        src=item.avatar
                                        alt=item.title
                                        width="80px"
                                        height="auto"
                                        style="border-radius: 8px;"
                                    )
                                td #{item.title}
                                td #{item.listen}
                                td
                                    if (item.status === "active")
                                        a(
                                            href="javascript:;"
                                            class="badge badge-success"
                                            data-status="active"
                                            data-id=item.id
                                            button-change-status
                                        ) Hoạt động
                                    else
                                        a(
                                            href="javascript:;"
                                            class="badge badge-danger"
                                            data-status="inactive"
                                            data-id=item.id
                                            button-change-status
                                        ) Dừng hoạt động
                                td
                                    a(
                                        href=`/${prefixAdmin}/songs/detail/${item.id}`
                                        class="btn btn-secondary btn-sm mr-1"
                                    ) Chi tiết
                                    a(
                                        href=`/${prefixAdmin}/songs/edit/${item.id}`
                                        class="btn btn-warning btn-sm mr-1"
                                    ) Sửa
                                    button(
                                        class="btn btn-danger btn-sm"
                                        button-delete
                                        data-id=item.id
                                    ) Xóa