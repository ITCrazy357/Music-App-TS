extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
    .container-fluid.px-4.px-lg-5.my-3
    .song-trash-page
        .row
            .col-12
                +box-head(pageTitle)

        .card.mb-3
        .song-trash-card
            .card-header Thùng rác bài hát
            .card-body
                .row
                    .col-12.text-right.mb-3
                        a(
                            href=`/${prefixAdmin}/songs`
                            class="btn btn-outline-secondary"
                        ) Quay lại

                if songs.length > 0
                    table.table.table-hover.table-sm.mt-3
                        thead
                            tr
                                th STT
                                th Hình ảnh
                                th Tiêu đề
                                th Chủ đề
                                th Ca sĩ
                                th Hành động
                        tbody
                            each item, index in songs
                                tr
                                    td #{index + 1}
                                    td
                                        if item.avatar
                                            img(
                                                src=item.avatar
                                                alt=item.title
                                            )
                                    td #{item.title}
                                    td #{item.topicName || item.topicId}
                                    td #{item.singerName || item.singerId}
                                    td
                                        button(
                                            type="button"
                                            class="btn btn-success btn-sm mr-1"
                                            button-restore
                                            data-id=item.id
                                        )
                                            i.fa-solid.fa-rotate-left.mr-1
                                            | Khôi phục

                                        button(
                                            type="button"
                                            class="btn btn-danger btn-sm"
                                            button-delete-permanent
                                            data-id=item.id
                                        )
                                            i.fa-solid.fa-trash-xmark.mr-1
                                            | Xóa vĩnh viễn
                else
                    .alert.alert-secondary Không có bài hát nào trong thùng rác

        form(
            action=""
            method="POST"
            id="form-restore-item"
            data-path=`/${prefixAdmin}/songs/restore`
        )

        form(
            action=""
            method="POST"
            id="form-delete-permanent-item"
            data-path=`/${prefixAdmin}/songs/delete-permanent`
        )