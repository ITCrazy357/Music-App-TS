extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
    .container-fluid.px-4.px-lg-5.my-3
        .row 
            .col-12 
                +box-head(pageTitle)

        .card.mb-3.admin-form-card
            .card-header Chỉnh sửa bài hát
            .card-body
                form.admin-form(
                    action=`/${prefixAdmin}/songs/edit/${song.id}?_method=PATCH`
                    method="POST"
                    enctype="multipart/form-data"
                )
                    .row
                        .col-md-6
                            .form-group
                                label(for="title") Tiêu đề
                                input.form-control(type="text" id="title" name="title" required value=song.title)
                        .col-md-6
                            .form-group
                                label(for="slug") Slug
                                input.form-control(type="text" id="slug" name="slug" placeholder="Tự động tạo từ tiêu đề nếu để trống" value=song.slug)
                        .col-md-6
                            .form-group
                                label(for="topicId") Chủ đề
                                select.form-control(name="topicId" id="topicId" required)
                                    option(value="") Chọn chủ đề
                                    each topic in topics
                                        option(value=topic.id selected=(topic.id == song.topicId ? true : false)) #{topic.title}
                        .col-md-6
                            .form-group
                                label(for="singerId") Ca sĩ
                                select.form-control(name="singerId" id="singerId" required)
                                    option(value="") Chọn ca sĩ
                                    each singer in singers
                                        option(value=singer.id selected=(singer.id == song.singerId ? true : false)) #{singer.fullName}
                        .col-md-6
                            .form-group
                                label Trạng thái
                                .d-flex.align-items-center
                                    .form-check.form-check-inline
                                        input.form-check-input(type="radio" id="statusActive" name="status" value="active" checked=(song.status == "active" ? true : false))
                                        label.form-check-label(for="statusActive") Hoạt động
                                    .form-check.form-check-inline.ml-3
                                        input.form-check-input(type="radio" id="statusInactive" name="status" value="inactive" checked=(song.status == "inactive" ? true : false))
                                        label.form-check-label(for="statusInactive") Dừng hoạt động
                    .form-group
                        label(for="description") Mô tả
                        textarea.form-control(id="description" name="description" rows="4") #{song.description}
                    .form-group
                        label(for="lyrics") Lời bài hát
                        textarea.form-control(id="lyrics" name="lyrics" rows="4") #{song.lyrics}
                    .row
                        .col-md-6
                            .form-group
                                label(for="avatar") Ảnh bìa
                                input.form-control-file(type="file" id="avatar" name="avatar" accept="image/*")
                                if song.avatar
                                    img.admin-preview-image(src=song.avatar)
                        .col-md-6
                            .form-group
                                label(for="audio") File audio
                                input.form-control-file(type="file" id="audio" name="audio" accept="audio/*")
                                if song.audio
                                    audio(controls class="admin-preview-audio")
                                        source(src=song.audio)
                                        | Trình duyệt của bạn không hỗ trợ thẻ audio.
                    .form-group.mt-4
                        button(type="submit" class="btn btn-warning")
                            i.fa-solid.fa-save.mr-1
                            | Cập nhật
                        a(href=`/${prefixAdmin}/songs` class="btn btn-secondary ml-2")
                            i.fa-solid.fa-arrow-left.mr-1
                            | Hủy
