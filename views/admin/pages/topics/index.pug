extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/pagination.pug
include ../../mixins/filter-status.pug
include ../../mixins/form-change-multi.pug

block main 
    .topic-index-page
        .row.mb-4 
            .col-12 
                +box-head(pageTitle)

        .card.mb-3
            .card-header Bộ lọc và Tìm kiếm
            .card-body
                .row
                    .col-6
                        +filter-status(filterStatus)
                    .col-6
                        form(id="form-search")
                            .input-group
                                input(
                                    type="text"
                                    placeholder="Nhập từ khóa"
                                    name="keyword"
                                    class="form-control"
                                    value=keyword
                                )
                                .input-group-append
                                    button(
                                        class="btn btn-success"
                                        type="submit"
                                    ) Tìm

        .topic-index-card
            .topic-index-header
                i.fa-solid.fa-list
                span Danh sách chủ đề
            .topic-index-body
                .row.mb-3
                    .col-8 
                        if role && (role.permissions.includes("topics_edit") || role.title === "Admin" || role.title === "Content")
                            +form-change-multi(`/${prefixAdmin}/topics/change-multi?_method=PATCH`)
                    .col-4.text-right 
                        if role && (role.permissions.includes("topics_create") || role.title === "Admin" || role.title === "Content")
                            a(
                                href=`/${prefixAdmin}/topics/create`
                                class="btn btn-outline-success mr-2"
                            )
                                i.fa-solid.fa-plus.mr-1
                                | Thêm mới
                        if role && (role.permissions.includes("topics_delete") || role.title === "Admin")
                            a(
                                href=`/${prefixAdmin}/topics/trash`
                                class="btn btn-outline-danger"
                            )
                                i.fa-solid.fa-trash-can.mr-1
                                | Thùng rác

                if topics.length > 0
                    table(
                        class="table table-hover table-sm mt-3"
                        checkbox-multi
                    )
                        thead
                            tr
                                th
                                    input(type="checkbox" name="checkall")
                                th STT
                                th Hình ảnh
                                th Tiêu đề
                                th Trạng thái
                                th Hành động
                        tbody
                            each item, index in topics
                                tr 
                                    td
                                        input(
                                            type="checkbox"
                                            name="id"
                                            value=item.id
                                        )
                                    td #{index + 1}
                                    td
                                        img(
                                            src=item.avatar
                                            alt=item.title
                                            width="100px"
                                            height="auto"
                                            style="border-radius: 8px;"
                                        )
                                    td #{item.title}
                                    td
                                        if (item.status === "active")
                                            a(
                                                href="javascript:;"
                                                class="badge badge-success"
                                                data-status="active"
                                                data-id=item.id
                                                button-change-status
                                            ) Hoạt động
                                        else
                                            a(
                                                href="javascript:;"
                                                class="badge badge-danger"
                                                data-status="inactive"
                                                data-id=item.id
                                                button-change-status
                                            ) Dừng hoạt động
                                    td
                                        a(
                                            href=`/${prefixAdmin}/topics/detail/${item.id}`
                                            class="btn btn-secondary btn-sm mr-1"
                                        ) Chi tiết
                                        if role && (role.permissions.includes("topics_edit") || role.title === "Admin" || role.title === "Content")
                                            a(
                                                href=`/${prefixAdmin}/topics/edit/${item.id}`
                                                class="btn btn-warning btn-sm mr-1"
                                            ) Sửa
                                        if role && (role.permissions.includes("topics_delete") || role.title === "Admin")
                                            button(
                                                class="btn btn-danger btn-sm"
                                                button-delete
                                                data-id=item.id
                                            ) Xóa
                else
                    div.alert.alert-secondary.mt-3 Không có chủ đề nào.

        +pagination(pagination)

        form(
            action=""
            method="POST"
            id="form-change-status"
            data-path=`/${prefixAdmin}/topics/change-status`
        )

        form(
            action=""
            method="POST"
            id="form-delete-item"
            data-path=`/${prefixAdmin}/topics/delete`
        )