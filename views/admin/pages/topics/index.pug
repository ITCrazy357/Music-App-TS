extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
    .topic-index-page
        .row.mb-4 
            .col-12 
                +box-head(pageTitle)

        .topic-index-card
            .topic-index-header
                i.fa-solid.fa-list
                span Danh sách chủ đề
            .topic-index-body
                .row 
                    .col-8 
                    .col-4.text-right 
                        a(
                            href=`/${prefixAdmin}/topics/create`
                            class="btn btn-outline-success mr-2"
                        )
                            i.fa-solid.fa-plus.mr-1
                            | Thêm mới
                        a(
                            href=`/${prefixAdmin}/topics/trash`
                            class="btn btn-outline-danger"
                        )
                            i.fa-solid.fa-trash-can.mr-1
                            | Thùng rác

                if topics.length > 0
                    table(
                        class="table table-hover table-sm mt-3"
                        checkbox-multi
                    )
                        thead
                            tr
                                th STT
                                th Hình ảnh
                                th Tiêu đề
                                th Trạng thái
                                th Hành động
                        tbody
                            each item, index in topics
                                tr 
                                    td #{index + 1}
                                    td
                                        img(
                                            src=item.avatar
                                            alt=item.title
                                            width="100px"
                                            height="auto"
                                            style="border-radius: 8px;"
                                        )
                                    td #{item.title}
                                    td
                                        if (item.status === "active")
                                            a(
                                                href="javascript:;"
                                                class="badge badge-success"
                                                data-status="active"
                                                data-id=item.id
                                                button-change-status
                                            ) Hoạt động
                                        else
                                            a(
                                                href="javascript:;"
                                                class="badge badge-danger"
                                                data-status="inactive"
                                                data-id=item.id
                                                button-change-status
                                            ) Dừng hoạt động
                                    td
                                        a(
                                            href=`/${prefixAdmin}/topics/detail/${item.id}`
                                            class="btn btn-secondary btn-sm mr-1"
                                        ) Chi tiết
                                        a(
                                            href=`/${prefixAdmin}/topics/edit/${item.id}`
                                            class="btn btn-warning btn-sm mr-1"
                                        ) Sửa
                                        button(
                                            class="btn btn-danger btn-sm"
                                            button-delete
                                            data-id=item.id
                                        ) Xóa
                else
                    div.alert.alert-secondary.mt-3 Không có chủ đề nào.

        form(
            action=""
            method="POST"
            id="form-change-status"
            data-path=`/${prefixAdmin}/topics/change-status`
        )

        form(
            action=""
            method="POST"
            id="form-delete-item"
            data-path=`/${prefixAdmin}/topics/delete`
        )