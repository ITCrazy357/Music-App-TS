extends ../../layouts/default.pug
include ../../../client/mixins/box-head.pug

block main
    .container-fluid.px-4.px-lg-5.my-4

        .row
            .col-12
                +box-head(pageTitle)

        .row.g-4

            .col-xl-3.col-md-6
                .card.dashboard-card
                    .card-header
                        i.fa-solid.fa-music.me-2
                        | Bài hát

                    .card-body
                        .dashboard-number 10

                        .dashboard-stats
                            p.active-count
                                i.fa-solid.fa-circle-check.me-2
                                | Đang hoạt động: 8

                            p.inactive-count
                                i.fa-solid.fa-circle-xmark.me-2
                                | Dừng hoạt động: 2

            .col-xl-3.col-md-6
                .card.dashboard-card
                    .card-header
                        i.fa-solid.fa-layer-group.me-2
                        | Chủ đề

                    .card-body
                        .dashboard-number 5

                        .dashboard-stats
                            p.active-count
                                i.fa-solid.fa-circle-check.me-2
                                | Đang hoạt động: 5

                            p.inactive-count
                                i.fa-solid.fa-circle-xmark.me-2
                                | Dừng hoạt động: 0

            .col-xl-3.col-md-6
                .card.dashboard-card
                    .card-header
                        i.fa-solid.fa-microphone.me-2
                        | Ca sĩ

                    .card-body
                        .dashboard-number 8

                        .dashboard-stats
                            p.active-count
                                i.fa-solid.fa-circle-check.me-2
                                | Đang hoạt động: 7

                            p.inactive-count
                                i.fa-solid.fa-circle-xmark.me-2
                                | Dừng hoạt động: 1

            .col-xl-3.col-md-6
                .card.dashboard-card
                    .card-header
                        i.fa-solid.fa-users.me-2
                        | Người dùng

                    .card-body
                        .dashboard-number 20

                        .dashboard-stats
                            p.active-count
                                i.fa-solid.fa-circle-check.me-2
                                | Đang hoạt động: 18

                            p.inactive-count
                                i.fa-solid.fa-circle-xmark.me-2
                                | Dừng hoạt động: 2